#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# ///
"""Source-checkout launcher for fabric_agent_installer._installer.main.

When installed via `pip install fabric-skills-settings`, the wheel registers
`install-fabric-agent` as a console-script entry point that calls
`fabric_agent_installer._installer:main` directly. This file is the
equivalent entry point for running from a source checkout (before the wheel
is built), e.g. `./setup.sh --profile claude --target /path/to/repo` or
`uv run cli/install-fabric-agent ...`.
"""

from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from fabric_agent_installer._installer import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
