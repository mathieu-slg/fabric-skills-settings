# Fabric Agent Pack - target repository environment template.
# Copy to .env locally if needed. Never commit .env.
#
# Workspace identity and resource IDs are auto-generated by switch.py after
# running tool/workspace/init.py — do not edit the auto-generated block below.
# Only add credentials or project-specific overrides in this section.

# Fabric MCP server (Docker container).
# Run from the source repo: `cd server && docker compose up --build`.
# setup.{ps1,sh} writes this value; defaults to http://127.0.0.1:8000.
# FABRIC_SERVER_URL=http://127.0.0.1:8000

